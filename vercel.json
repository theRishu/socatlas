{
  "version": 2,
  "builds": [
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "site"
      }
    }
  ],
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/risk_threat_intel",
      "destination": "/governance/risk_threat_intel/",
      "permanent": true
    },
    {
      "source": "/cyber_threats",
      "destination": "/threats/cyber_threats/",
      "permanent": true
    },
    {
      "source": "/ioc_ioa_mitre",
      "destination": "/governance/ioc_ioa_mitre/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
