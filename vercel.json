{
  "version": 2,
  "builds": [
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "site"
      }
    }
  ],
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1/index.html"
    }
  ]
}
